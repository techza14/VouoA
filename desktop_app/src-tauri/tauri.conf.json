{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "VouoA Desktop",
    "version":  "1.0.0",
    "identifier":  "com.vouoa.desktop",
    "build":  {
                  "frontendDist":  "../src"
              },
    "app":  {
                "withGlobalTauri":  true,
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "VouoA Desktop",
                                    "width":  1220,
                                    "height":  820,
                                    "minWidth":  980,
                                    "minHeight":  720
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "resources":  [
                                     "resources/bridge/*"
                                 ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
